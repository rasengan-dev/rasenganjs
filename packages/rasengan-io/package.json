{
  "name": "@rasenganjs/io",
  "version": "1.0.0-beta.1",
  "description": "Real-time communication for Rasengan.JS applications using Socket.IO",
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rasengan-dev/rasenganjs",
    "directory": "packages/rasengan-io"
  },
  "scripts": {
    "build:clean": "rimraf ./dist",
    "build": "pnpm build:clean && tsup",
    "pack": "pnpm pack --pack-destination ./release",
    "deploy": "pnpm publish --access public",
    "deploy:beta": "pnpm run deploy --tag beta"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "socket.io-client": "^4.*"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "rimraf": "^6.1.3",
    "socket.io-client": "^4.*",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "files": [
    "dist/",
    "CHANGELOG.md",
    "LICENSE.md",
    "README.md"
  ]
}
