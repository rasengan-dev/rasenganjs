    "@vitejs/release-scripts": "^1.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "picocolors": "^1.1.1",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "tsup": "^8.5.1"
